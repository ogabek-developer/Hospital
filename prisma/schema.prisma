// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admins {
  id             String     @id @unique @default(uuid())
  phone_number   String     @unique
  password       String
  refresh_token  String?
  is_super_admin Boolean    @default(false)
  hospital_id    String?
  hospital       Hospitals? @relation(fields: [hospital_id], references: [id])
  created_at     DateTime   @default(now())
  updated_at     DateTime   @default(now())
}

model Doctors {
  id             String      @id @unique @default(uuid())
  phone_number   String      @unique
  password       String
  refresh_token  String?
  specialization String
  hospital_id    String
  department_id  String
  hospital       Hospitals   @relation(fields: [hospital_id], references: [id])
  department     Departments @relation(fields: [department_id], references: [id])
  created_at     DateTime    @default(now())
  updated_at     DateTime    @default(now())
}

model Hospitals {
  id             String           @id @unique @default(uuid())
  name           String
  address        String
  phone          String           @unique
  admins         Admins[]
  doctors        Doctors[]
  potients       Potients[]
  departments    Departments[]
  answers        Answers[]
  questionnaires Questionnaires[]
  created_at     DateTime         @default(now())
  updated_at     DateTime         @default(now())
}

model Potients {
  id           String    @id @unique @default(uuid())
  hospital_id  String
  phone_number String    @unique
  answers      Answers[]
  hospital     Hospitals @relation(fields: [hospital_id], references: [id])
  created_at   DateTime  @default(now())
  updated_at   DateTime  @default(now())

  @@unique([hospital_id])
}

model Departments {
  id             String           @id @unique @default(uuid())
  name           String
  hospital_id    String
  doctors        Doctors[]
  questionnaires Questionnaires[]
  hospital       Hospitals        @relation(fields: [hospital_id], references: [id])
  created_at     DateTime         @default(now())
  updated_at     DateTime         @default(now())

  @@unique([name, hospital_id])
}

model Questionnaires {
  id            String      @id @unique @default(uuid())
  hospital_id   String
  department_id String
  title         String
  question      Questions[]
  hospital      Hospitals   @relation(fields: [hospital_id], references: [id])
  department    Departments @relation(fields: [department_id], references: [id])
  is_active     Boolean     @default(true)
  created_at    DateTime    @default(now())
  updated_at    DateTime    @default(now())

  @@unique([hospital_id, department_id])
}

model Questions {
  id               String         @id @unique @default(uuid())
  questionnaire_id String
  question_text    String
  answers          Answers[]
  questionnaire    Questionnaires @relation(fields: [questionnaire_id], references: [id])
  created_at       DateTime       @default(now())
  updated_at       DateTime       @default(now())

  @@unique([questionnaire_id, question_text])
}

model Answers {
  id          String    @id @default(uuid())
  hospital_id String
  question_id String
  potient_id  String
  answer_text String
  potient     Potients  @relation(fields: [potient_id], references: [id])
  hospital    Hospitals @relation(fields: [hospital_id], references: [id])
  question    Questions @relation(fields: [question_id], references: [id])
  created_at  DateTime  @default(now())
  updated_at  DateTime  @updatedAt

  @@unique([hospital_id, question_id, potient_id])
}
