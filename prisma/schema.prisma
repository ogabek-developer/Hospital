// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admins {
  id             Int       @id @unique @default(autoincrement())
  phone_number   String    @unique
  password       String
  is_super_admin Boolean   @default(false)
  hospital_id    Int
  hospital       Hospitals @relation(fields: [hospital_id], references: [id])
  created_at     DateTime  @default(now())
  updated_at     DateTime  @default(now())
}

model Doctors {
  id             Int         @id @unique @default(autoincrement())
  phone_number   String      @unique
  password       String
  specialization String
  hospital_id    Int
  department_id  Int
  hospital       Hospitals   @relation(fields: [hospital_id], references: [id])
  department     Departments @relation(fields: [department_id], references: [id])
  created_at     DateTime    @default(now())
  updated_at     DateTime    @default(now())
}

model Hospitals {
  id             Int              @id @unique @default(autoincrement())
  name           String
  address        String
  phone          String           @unique
  admins         Admins[]
  doctors        Doctors[]
  potients       Potients[]
  departments    Departments[]
  answers        Answers[]
  questionnaires Questionnaires[]
  created_at     DateTime         @default(now())
  updated_at     DateTime         @default(now())
}

model Potients {
  id          Int       @id @unique @default(autoincrement())
  full_name   String
  hospital_id Int
  answers     Answers[]
  hospital    Hospitals @relation(fields: [hospital_id], references: [id])
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now())

  @@unique([full_name, hospital_id])
}

model Departments {
  id             Int              @id @unique @default(autoincrement())
  name           String
  hospital_id    Int
  doctors        Doctors[]
  questionnaires Questionnaires[]
  hospital       Hospitals        @relation(fields: [hospital_id], references: [id])
  created_at     DateTime         @default(now())
  updated_at     DateTime         @default(now())
  
  @@unique([name, hospital_id])
}

model Questionnaires {
  id            Int         @id @unique @default(autoincrement())
  hospital_id   Int
  department_id Int
  title         String
  question      Questions[]
  hospital      Hospitals   @relation(fields: [hospital_id], references: [id])
  department    Departments @relation(fields: [department_id], references: [id])
  is_active     Boolean     @default(true)
  created_at    DateTime    @default(now())
  updated_at    DateTime    @default(now())
}

model Questions {
  id               Int            @id @unique @default(autoincrement())
  questionnaire_id Int
  question_text    String
  answers          Answers[]
  questionnaire    Questionnaires @relation(fields: [questionnaire_id], references: [id])
  created_at       DateTime       @default(now())
  updated_at       DateTime       @default(now())

  @@unique([questionnaire_id, question_text])
}

model Answers {
  id          Int       @id @unique @default(autoincrement())
  hospital_id Int
  question_id Int
  answer_text String
  potient_id  Int
  potient     Potients  @relation(fields: [potient_id], references: [id])
  hospital    Hospitals @relation(fields: [hospital_id], references: [id])
  question    Questions @relation(fields: [question_id], references: [id])
  created_at  DateTime  @default(now())
  updated_at  DateTime  @default(now())
}
